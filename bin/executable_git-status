#!/bin/bash

# Define colors
RED='\033[0;31m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

target_dir="${1:-$(pwd)}"

# Ensure target_dir exists
if [ ! -d "$target_dir" ]; then
    echo "Directory $target_dir does not exist."
    exit 1
fi

# Loop through subdirectories
for repo in "$target_dir"/*; do
    [ -d "$repo" ] || continue

    echo -e "${PURPLE}${repo}${NC}"

    if [ -d "$repo/.git" ]; then
        (
            cd "$repo" || exit

            is_dirty=0
            
            # Check for modified/added/deleted files (staged or unstaged)
            if [ -n "$(git status --porcelain)" ]; then
                echo -e "${RED}Dirty (Modified/Untracked)${NC}"
                is_dirty=1
            fi

            # Check for unpushed commits
            # Check if upstream is configured
            if git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
                ahead=$(git rev-list --count @{u}..HEAD)
                behind=$(git rev-list --count HEAD..@{u})

                if [ "$ahead" -gt 0 ]; then
                    echo -e "${RED}Ahead by $ahead commit(s)${NC}"
                    is_dirty=1
                fi
                if [ "$behind" -gt 0 ]; then
                    echo -e "${RED}Behind by $behind commit(s)${NC}"
                    is_dirty=1
                fi
            else
                 # echo -e "${RED}No upstream configured${NC}" # Optional: Warn about no upstream
                 :
            fi

            if [ "$is_dirty" -eq 0 ]; then
                echo "Nothing to commit"
            fi
        )
    else
        echo "Not a git repository"
    fi
    echo
done