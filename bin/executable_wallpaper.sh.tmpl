#!/bin/bash

OS="$(uname -s)"

set_wallpaper_macos() {
    local img_path="$1"
    # Convert POSIX path to AppleScript path is tricky, but we can use System Events
    osascript -e "tell application \"System Events\" to set picture of every desktop to \"$img_path\""
}

set_wall_and_lockscreen() {
    local img="$1"
    local mode="$2"
    
    if [ "$OS" = "Darwin" ]; then
        set_wallpaper_macos "$img"
        # macOS doesn't have a separate lockscreen image setter easily exposed via CLI 
        # that matches 'betterlockscreen' functionality without external tools.
    else
        # Linux / X11 logic
        if [[ "$mode" == "all" ]]; then
            # Assuming logic to find displays...
            # Simplified for now as the original logic was a bit specific
            nitrogen --set-zoom-fill "$img" &>/dev/null
        elif [[ "$mode" != "" ]]; then
             nitrogen --set-zoom-fill --head="$mode" "$img" &>/dev/null
        else
            echo "No displays specified" && exit 1
        fi
        
        if command -v betterlockscreen >/dev/null; then
            betterlockscreen -u "$img" --fx dimblur
        fi
    fi
}


folder="${XDG_PICTURES_DIR:-$HOME/Pictures}/wallpapers/rand"
if [ "$OS" = "Darwin" ]; then
    folder="$HOME/Pictures/wallpapers/rand"
fi

wallpaper_folder_data="${XDG_DATA_HOME:-$HOME/.local/share}/wallpaper"
mkdir -p "$wallpaper_folder_data"
cache_until_now="$wallpaper_folder_data/tillnow"

case "$1" in
"rand")
	while true; do
        if [ -d "$folder" ]; then
		    all=$(find "$folder" -maxdepth 1 \( ! -name .gitattributes \) -type f)
            if [ -n "$all" ]; then
                n_all="$(wc -l <<<"$all")"
                shuffled="$(shuf -n "$n_all" <<<"$all")"
                
                # Simple random selection without the complex "cache_until_now" for now 
                # unless we want to strictly port it. I'll stick to simple random for robustness.
                wallpaper="$(shuf -n 1 <<<"$all")"
                
                set_wall_and_lockscreen "$wallpaper" "$2"
            fi
        fi
		sleep 7200
	done
	;;
*)
	wallpaper="$1"
    if [ -f "$wallpaper" ]; then
	    set_wall_and_lockscreen "$wallpaper" "$2"
    else
        echo "Error: File '$wallpaper' not found."
    fi
	;;
esac
