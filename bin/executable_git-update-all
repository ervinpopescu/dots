#!/bin/bash

set -e
current=$(git branch | grep '\*' | awk '{print $2}')
mapfile -t all_branches < <(git branch | sed 's/\*//' | awk '{print $1}')
for b in "${all_branches[@]}"; do
	echo Checkin\' out branch $b...
	git checkout $b
	echo Fetchin\' branch $b...
	git fetch
	echo Pullin\' branch $b...
	git pull
	echo
done
git checkout $current
