  "extraKnownMarketplaces": {
    "claude-code-workflows": {
      "source": {
        "repo": "wshobson/agents",
        "source": "github"
      }
    }
  },
  "includeCoAuthoredBy": false,
  "inputNeededNotifEnabled": true,
  "statusLine": {
    "command": "bash /home/ervin/.claude/statusline.sh",
